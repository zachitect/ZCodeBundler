<Window x:Class="ZCodeBundler.DecodedBundleViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Decoded Bundle Viewer"
        Height="800"
        Width="1600"
        MinHeight="520"
        MinWidth="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="DiffCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="Padding" Value="4,2" />
        </Style>
        <Style x:Key="DiffLineNumberStyle" TargetType="TextBlock" BasedOn="{StaticResource DiffCellTextStyle}">
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8" />
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Background="#F5F6F8">
        <Border DockPanel.Dock="Top" Margin="8" Padding="8" Background="White" BorderBrush="#C8CDD6" BorderThickness="1" CornerRadius="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Margin="0,0,12,0">
                    <TextBlock x:Name="StatusTextBlock" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock x:Name="TargetPathTextBlock" Margin="0,4,0,0" Foreground="#666666" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Row="0" Grid.Column="1" x:Name="ApplyChangesButton" Content="Apply Changes" Padding="12,4" MinWidth="120" IsEnabled="False" Click="ApplyChangesButton_Click" />
            </Grid>
        </Border>

        <Border Margin="8" Background="White" BorderBrush="#C8CDD6" BorderThickness="1" CornerRadius="0">
            <DataGrid x:Name="DiffRowsDataGrid"
              ItemsSource="{Binding DiffRows}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              HeadersVisibility="Column"
              GridLinesVisibility="None"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              CanUserReorderColumns="False"
              CanUserResizeColumns="False"
              CanUserSortColumns="False"
              RowHeaderWidth="0"
              BorderThickness="0"
              SelectionMode="Extended"
              SelectionUnit="FullRow"
              ScrollViewer.HorizontalScrollBarVisibility="Auto"
              ScrollViewer.VerticalScrollBarVisibility="Auto">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="#"
                                Width="50"
                                Binding="{Binding SourceLineNumberText}"
                                ElementStyle="{StaticResource DiffLineNumberStyle}" />

                    <DataGridTemplateColumn Header="Source / current file"
                                    Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding SourceBackground}">
                                    <TextBlock Style="{StaticResource DiffCellTextStyle}"
                                       Text="{Binding SourceText}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="#"
                                Width="50"
                                Binding="{Binding DecodedLineNumberText}"
                                ElementStyle="{StaticResource DiffLineNumberStyle}" />

                    <DataGridTemplateColumn Header="Decoded bundle content"
                                    Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding DecodedBackground}">
                                    <TextBlock Style="{StaticResource DiffCellTextStyle}"
                                       Text="{Binding DecodedText}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</Window>