<Window x:Class="ZCodeBundler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZCodeBundler 1.0.0 | Zach.Zheng | Zachitect.com"
        Height="800"
        Width="1000"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Icon="Assets/ZCodeBundler.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="ColorBorderDefault" Color="#C8CDD6" />
        <SolidColorBrush x:Key="ColorBorderHover" Color="#7AA7E8" />
        <SolidColorBrush x:Key="ColorAccent" Color="#256D9B" />
        <SolidColorBrush x:Key="ColorSurface" Color="White" />
        <SolidColorBrush x:Key="ColorSurfaceHover" Color="#F4F8FF" />
        <SolidColorBrush x:Key="ColorSurfaceSelected" Color="#EAF2FF" />
        <SolidColorBrush x:Key="ColorTextMuted" Color="#666666" />
        <SolidColorBrush x:Key="ColorSeparator" Color="#E1E5EC" />
        <SolidColorBrush x:Key="ColorWindowBackground" Color="#F5F6F8" />
        <SolidColorBrush x:Key="ColorAlternateRow" Color="#F7F9FC" />

        <Thickness x:Key="WindowPadding" Left="8" Top="8" Right="8" Bottom="8" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ColorSurface}" />
            <Setter Property="BorderBrush" Value="{StaticResource ColorBorderDefault}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="8" />
        </Style>

        <Style x:Key="CompactActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource ColorSurface}" />
            <Setter Property="BorderBrush" Value="{StaticResource ColorBorderDefault}" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ColorSurfaceHover}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource ColorBorderHover}" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource ColorAccent}" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ColorSurfaceSelected}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource ColorAccent}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwitchToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="#D6DAE2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}">
                            <Border x:Name="SwitchTrack"
                                    CornerRadius="6"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource ColorBorderDefault}"
                                    BorderThickness="1" />

                            <Border x:Name="SwitchThumb"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="4"
                                    Background="White"
                                    HorizontalAlignment="Left"
                                    Margin="3"
                                    SnapsToDevicePixels="True" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{StaticResource ColorBorderHover}" />
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#E1E5EC" />
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{StaticResource ColorAccent}" />
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{StaticResource ColorAccent}" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SwitchTrack" Property="Opacity" Value="0.55" />
                                <Setter TargetName="SwitchThumb" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactListViewStyle" TargetType="ListView">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource ColorSurface}" />
            <Setter Property="BorderBrush" Value="{StaticResource ColorBorderDefault}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListView">
                        <Border x:Name="ListViewBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ScrollViewer Focusable="False">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ListViewBorder" Property="BorderBrush" Value="{StaticResource ColorBorderHover}" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ListViewBorder" Property="BorderBrush" Value="{StaticResource ColorAccent}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ListViewBorder" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SimpleListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{StaticResource ColorAlternateRow}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource ColorWindowBackground}"
            Padding="{StaticResource WindowPadding}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition x:Name="SelectedFilesAreaRow" Height="2*" />
                <RowDefinition Height="8" />
                <RowDefinition x:Name="DropAreaRow" Height="*" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="ZCodeBundler"
                           Padding="6,0,0,0"
                           FontSize="16"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Column="1"
                           Text="Create a clean text bundle from selected project files for LLM code context."
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource ColorTextMuted}"
                           FontSize="12"
                           TextWrapping="NoWrap" />
            </Grid>

            <Border Grid.Row="2"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource CardBorderStyle}"
                            Padding="5,4"
                            Background="#FBFCFE">
                        <DockPanel>
                            <TextBlock x:Name="TotalFilesTextBlock"
                                       DockPanel.Dock="Right"
                                       Text="Total selected files: 0"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ColorAccent}"
                                       Margin="16,0,0,0" />

                            <TextBlock x:Name="StatusMessageTextBlock"
                                       Text=""
                                       Foreground="{StaticResource ColorTextMuted}"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                    </Border>

                    <ListView Grid.Row="2"
                              x:Name="SelectedFilesListView"
                              SelectionMode="Extended"
                              AlternationCount="2"
                              Style="{StaticResource CompactListViewStyle}"
                              ItemContainerStyle="{StaticResource SimpleListViewItemStyle}"
                              SelectionChanged="SelectedFilesListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding FileType, Mode=OneWay}"
                                               Foreground="{StaticResource ColorTextMuted}"
                                               TextWrapping="NoWrap"
                                               Margin="0,0,10,0" />

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding RelativePath, Mode=OneWay}"
                                               TextWrapping="NoWrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Select Folder"
                                Style="{StaticResource CompactActionButtonStyle}"
                                Click="SelectRootFolderButton_Click" />

                        <Button x:Name="ClearAllFilesButton"
                                Grid.Column="2"
                                Content="Clear All"
                                IsEnabled="False"
                                Style="{StaticResource CompactActionButtonStyle}"
                                Click="ClearAllFilesButton_Click" />

                        <Button x:Name="RemoveSelectedFilesButton"
                                Grid.Column="4"
                                Content="Remove Selected"
                                IsEnabled="False"
                                Style="{StaticResource CompactActionButtonStyle}"
                                Click="RemoveSelectedFilesButton_Click" />

                        <Button x:Name="CreateBundleButton"
                                Grid.Column="6"
                                Content="Create Bundle TXT"
                                IsEnabled="False"
                                Style="{StaticResource CompactActionButtonStyle}"
                                Click="CreateBundleButton_Click" />
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="3"
                          Height="2"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="#C8CDD6"
                          Cursor="SizeNS"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          MouseDoubleClick="ListDropGridSplitter_MouseDoubleClick" />

            <Border Grid.Row="4"
                    x:Name="FolderDropArea"
                    AllowDrop="True"
                    Style="{StaticResource CardBorderStyle}"
                    Background="#FBFCFE"
                    DragEnter="FolderDropArea_DragEnter"
                    DragOver="FolderDropArea_DragOver"
                    Drop="FolderDropArea_Drop">
                <Grid>
                    <Rectangle Stroke="{StaticResource ColorSeparator}"
                               StrokeThickness="2"
                               StrokeDashArray="4 3"
                               RadiusX="5"
                               RadiusY="5"
                               Fill="White" />

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="Drop folders or files to add them to the bundle"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource ColorAccent}"
                                   FontSize="16"
                                   FontWeight="SemiBold" />

                        <TextBlock Text="Folders add all known files, or open the tree selector when enabled. Files are added directly."
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource ColorTextMuted}"
                                   FontSize="12"
                                   Margin="0,6,0,0" />

                        <TextBlock Text="Unknown file types are ignored unless the unknown-type option is enabled."
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource ColorTextMuted}"
                                   FontSize="11"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="6"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Ask about unknown file types"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource ColorTextMuted}"
                                   Margin="0,0,6,0" />

                        <ToggleButton x:Name="AskAboutUnknownFileTypesCheckBox"
                                      Style="{StaticResource SwitchToggleButtonStyle}"
                                      IsChecked="False" />
                    </StackPanel>

                    <StackPanel Grid.Column="4"
                                Grid.ColumnSpan="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="Use tree selection"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource ColorTextMuted}"
                                   Margin="0,0,6,0" />

                        <ToggleButton x:Name="UseTreeSelectionCheckBox"
                                      Style="{StaticResource SwitchToggleButtonStyle}"
                                      IsChecked="False" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
